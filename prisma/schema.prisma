// Prisma schema pour CRM Next.js avec PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id        String   @id @default(cuid())
  name      String
  plan      String   @default("free")
  createdAt DateTime @default(now())

  users      User[]
  leads      Lead[]
  deals      Deal[]
  clients    Client[]
  products   Product[]
  services   Service[]
  salesGoals SalesGoal[]
  /// Ventes réalisées pour cette société
  sales      Sale[]
}

model Product {
  id        String   @id @default(cuid())
  name      String
  company   Company  @relation(fields: [companyId], references: [id])
  companyId String
  createdAt DateTime @default(now())
  leads     Lead[]   @relation("LeadProducts")
  /// Intérêts exprimés par les clients pour ce produit, avec valeur estimative
  clientInterests ClientProductInterest[]
  /// Lignes de vente associées à ce produit
  saleItems       SaleItem[]
}

model Service {
  id        String   @id @default(cuid())
  name      String
  company   Company  @relation(fields: [companyId], references: [id])
  companyId String
  createdAt DateTime @default(now())
  leads     Lead[]   @relation("LeadServices")
  /// Intérêts exprimés par les clients pour ce service, avec valeur estimative
  clientInterests ClientServiceInterest[]
  /// Lignes de vente associées à ce service
  saleItems       SaleItem[]
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(AGENT)
  company   Company  @relation(fields: [companyId], references: [id])
  companyId String
  /// Activation de la double authentification (MFA)
  mfaEnabled Boolean @default(false)
  /// Secret TOTP (base32) pour génération des codes OTP ; présent si MFA configuré ou en attente de vérification
  mfaSecret  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities       Activity[]
  clientsConverted Client[]
  /// Objectifs commerciaux assignés à cet utilisateur
  salesGoals       SalesGoal[]
  /// Objectifs que cet utilisateur a définis (manager/admin)
  goalsSetBy       SalesGoal[] @relation("SalesGoalSetBy")
  /// Ventes réalisées par ce commercial
  sales            Sale[]
}

model Lead {
  id         String   @id @default(cuid())
  firstName  String
  lastName   String
  phone      String?
  email      String?
  source     String?
  /// Civilité (ex: M., Mme) issue du fichier Excel
  civility   String?
  /// Domaine d'activités du lead (secteur)
  activityDomain String?
  /// Nom de la compagnie au moment de la création du lead
  companyName String?
  /// Adresse / localisation (utile pour l'affichage sur la carte)
  location   String?
  /// Notes libres (ex: observation du fichier Excel)
  notes      String?
  status     LeadStatus @default(NEW)
  assignedTo String?
  company   Company  @relation(fields: [companyId], references: [id])
  companyId String
  createdAt DateTime @default(now())

  activities Activity[]
  /// Produits pour lesquels le prospect a exprimé un intérêt
  products   Product[] @relation("LeadProducts")
  /// Services pour lesquels le prospect a exprimé un intérêt
  services   Service[] @relation("LeadServices")
  /// Pièces jointes (fichiers) associées au prospect
  attachments LeadAttachment[]
  /// Événements / tâches de prospection enregistrés dans l'agenda
  agendaItems AgendaItem[]
}

/// Pièce jointe d'un prospect (fichier uploadé)
model LeadAttachment {
  id          String   @id @default(cuid())
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId      String
  fileName    String
  /// Type / extension du fichier (PDF, JPG, PNG, etc.)
  fileType    String
  /// Taille en octets
  fileSize    Int
  /// Chemin de stockage (ex: /uploads/leads/xxx/filename.pdf)
  storagePath String
  createdAt   DateTime @default(now())
}

model Deal {
  id         String   @id @default(cuid())
  title      String
  amount     Float
  stage      String
  probability Int?
  expectedCloseDate DateTime?
  assignedTo String?
  company   Company  @relation(fields: [companyId], references: [id])
  companyId String
}

model Client {
  id        String   @id @default(cuid())
  name      String
  /// Contact principal (téléphone ou email synthétique)
  contact   String?
  /// Email du client (copié depuis le lead)
  email     String?
  /// Téléphone du client (copié depuis le lead)
  phone     String?
  /// Source d'acquisition (ex: Facebook, WhatsApp, Site web...)
  source    String?
  /// Civilité (M., Mme, etc.)
  civility  String?
  /// Domaine d'activités (secteur)
  activityDomain String?
  /// Nom de la société côté client (copié depuis companyName du lead)
  companyName    String?
  /// Localisation / adresse
  location       String?
  /// Notes sur le client (observations)
  notes          String?
  /// Chiffre d'affaires total généré par ce client (somme des ventes)
  totalRevenue Float  @default(0)

  company   Company  @relation(fields: [companyId], references: [id])
  companyId String

  /// Ventes réalisées pour ce client
  sales     Sale[]

  /// Utilisateur ayant converti le prospect en client
  convertedById String?
  convertedAt   DateTime?
  convertedBy   User?   @relation(fields: [convertedById], references: [id])
  /// Produits pour lesquels le client est intéressé, avec valeur estimative
  productInterests ClientProductInterest[]
  /// Services pour lesquels le client est intéressé, avec valeur estimative
  serviceInterests ClientServiceInterest[]
}

/// Lien entre un client et un produit, avec une valeur estimative associée
model ClientProductInterest {
  id            String   @id @default(cuid())
  client        Client   @relation(fields: [clientId], references: [id])
  clientId      String
  product       Product  @relation(fields: [productId], references: [id])
  productId     String
  /// Valeur estimative associée à ce produit pour ce client
  estimatedValue Float   @default(0)
  createdAt     DateTime @default(now())

  @@unique([clientId, productId])
}

/// Lien entre un client et un service, avec une valeur estimative associée
model ClientServiceInterest {
  id            String   @id @default(cuid())
  client        Client   @relation(fields: [clientId], references: [id])
  clientId      String
  service       Service  @relation(fields: [serviceId], references: [id])
  serviceId     String
  /// Valeur estimative associée à ce service pour ce client
  estimatedValue Float   @default(0)
  createdAt     DateTime @default(now())

  @@unique([clientId, serviceId])
}

/// Vente (commande) réalisée pour un client, par un commercial, pour une société
model Sale {
  id        String   @id @default(cuid())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String
  /// Date effective de la vente
  date      DateTime
  /// Montant total de la vente (somme des lignes)
  amount    Float
  createdAt DateTime @default(now())

  items     SaleItem[]
}

/// Détail de ligne d'une vente (produit ou service vendu)
model SaleItem {
  id        String   @id @default(cuid())
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  saleId    String
  product   Product? @relation(fields: [productId], references: [id])
  productId String?
  service   Service? @relation(fields: [serviceId], references: [id])
  serviceId String?
  quantity  Int
  unitPrice Float
  lineTotal Float
}

model Activity {
  id        String   @id @default(cuid())
  type      ActivityType
  relatedTo String
  lead      Lead?    @relation(fields: [leadId], references: [id])
  leadId    String?
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  date      DateTime @default(now())
  content   String
}

enum Role {
  ADMIN
  MANAGER
  AGENT
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  LOST
  CONVERTED
}

enum ActivityType {
  CALL
  EMAIL
  WHATSAPP
  MEETING
  NOTE
}

/// Statut d'une tâche / événement dans l'agenda du prospect
enum AgendaStatus {
  TODO
  IN_PROGRESS
  DONE
}

/// Type de période pour les objectifs commerciaux
enum GoalPeriodType {
  MONTH
  QUARTER
  SEMESTER
  YEAR
}

/// Objectif commercial par commercial et par période (Mois, Trimestre, Semestre, Année)
model SalesGoal {
  id                 String         @id @default(cuid())
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId             String
  company            Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId          String
  periodType         GoalPeriodType
  periodStart        DateTime
  periodEnd          DateTime
  targetConversions  Int            @default(0)
  targetRevenue      Float          @default(0)
  /// Utilisateur (manager/admin) ayant défini cet objectif
  setById            String?
  setBy              User?          @relation("SalesGoalSetBy", fields: [setById], references: [id], onDelete: SetNull)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@unique([userId, periodType, periodStart])
}

/// Événement de l'agenda : action à mener sur un prospect (prospection → conversion)
model AgendaItem {
  id          String       @id @default(cuid())
  lead        Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId      String
  title       String
  description String?
  dueDate     DateTime
  status      AgendaStatus @default(TODO)
  createdAt   DateTime     @default(now())
}
